---
import "../styles/global.css";
import BenchmarkValueTimeline from "../components/BenchmarkValueTimeline";
import { aaApiModels, aaValueHistory, models } from "../lib/data";

const valueModels = aaValueHistory;
const topModels = [...valueModels]
  .sort((a, b) => (b.aaBenchmarkValue ?? 0) - (a.aaBenchmarkValue ?? 0))
  .slice(0, 20);

const firstRelease = valueModels.reduce<string | undefined>((earliest, m) => {
  if (!earliest || m.releaseDate < earliest) return m.releaseDate;
  return earliest;
}, undefined);
const lastRelease = valueModels.reduce<string | undefined>((latest, m) => {
  if (!latest || m.releaseDate > latest) return m.releaseDate;
  return latest;
}, undefined);
---

<!doctype html>
<html lang="en" class="bg-neutral-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Benchmark value · Frontier</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta
      name="description"
      content="Compare model value over time as Artificial Analysis Intelligence Index divided by the cost to run the full AA benchmark."
    />
  </head>
  <body class="min-h-screen px-3 py-6 text-neutral-100 sm:px-6 sm:py-10">
    <main class="mx-auto flex max-w-[1400px] flex-col gap-6 sm:gap-8">
      <nav class="flex items-center gap-3 text-xs text-neutral-500">
        <a href={import.meta.env.BASE_URL} class="text-amber-300 hover:underline">← all models</a>
        <span>/</span>
        <span class="text-neutral-400">value</span>
      </nav>

      <header class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
        <div class="flex flex-col gap-2">
          <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">
            Intelligence per benchmark-dollar
          </h1>
          <p class="max-w-3xl text-sm text-neutral-400">
            Artificial Analysis Intelligence Index divided by the dollar cost to
            run the full AA Intelligence benchmark. Higher means cheaper
            intelligence.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-2 text-xs">
          <div class="rounded border border-neutral-800 bg-neutral-900/50 p-2">
            <div class="text-[10px] uppercase tracking-wide text-neutral-500">models</div>
            <div class="font-mono text-neutral-100">{valueModels.length}/{aaApiModels.length}</div>
          </div>
          <div class="rounded border border-neutral-800 bg-neutral-900/50 p-2">
            <div class="text-[10px] uppercase tracking-wide text-neutral-500">first</div>
            <div class="font-mono text-neutral-100">{firstRelease ?? "—"}</div>
          </div>
          <div class="rounded border border-neutral-800 bg-neutral-900/50 p-2">
            <div class="text-[10px] uppercase tracking-wide text-neutral-500">latest</div>
            <div class="font-mono text-neutral-100">{lastRelease ?? "—"}</div>
          </div>
        </div>
      </header>

      <BenchmarkValueTimeline client:load models={valueModels} />

      <section class="flex flex-col gap-3">
        <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
          <h2 class="text-lg font-semibold text-neutral-200">Top value table</h2>
          <span class="text-xs text-neutral-500">
            Intelligence index / full AA benchmark-run cost · coverage from {aaApiModels.length} AA API models
          </span>
        </div>
        <div class="overflow-x-auto rounded-lg border border-neutral-800 bg-neutral-900/40 frontier-scroll">
          <table class="min-w-[760px] w-full text-sm">
            <thead class="bg-neutral-900 text-left text-xs uppercase tracking-wide text-neutral-400">
              <tr>
                <th class="px-3 py-2 text-right">#</th>
                <th class="px-3 py-2">Model</th>
                <th class="px-3 py-2">Provider</th>
                <th class="px-3 py-2">Release</th>
                <th class="px-3 py-2 text-right">AA intelligence</th>
                <th class="px-3 py-2 text-right">AA bench $</th>
                <th class="px-3 py-2 text-right">Index / $</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-800">
              {topModels.map((m, i) => (
                <tr class="hover:bg-neutral-900/70">
                  <td class="px-3 py-2 text-right font-mono text-neutral-500">{i + 1}</td>
                  <td class="px-3 py-2">
                    <a
                      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/models/${m.id}/`}
                      class="font-medium text-neutral-100 hover:text-amber-300 hover:underline"
                    >
                      {m.name}
                    </a>
                  </td>
                  <td class="px-3 py-2 text-neutral-300">{m.provider}</td>
                  <td class="px-3 py-2 font-mono text-xs text-neutral-400">{m.releaseDate}</td>
                  <td class="px-3 py-2 text-right font-mono text-neutral-200">
                    {m.aaIntelligenceIndex?.toFixed(2)}
                  </td>
                  <td class="px-3 py-2 text-right font-mono text-neutral-200">
                    ${m.aaBenchmarkTotalCost?.toFixed(2)}
                  </td>
                  <td class="px-3 py-2 text-right font-mono text-amber-300">
                    {m.aaBenchmarkValue?.toFixed(3)}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>
