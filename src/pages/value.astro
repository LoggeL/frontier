---
import "../styles/global.css";
import BenchmarkValueTimeline from "../components/BenchmarkValueTimeline";
import { models } from "../lib/data";

const valueModels = models.filter(
  (m) =>
    m.aaBenchmarkValue !== undefined &&
    m.aaBenchmarkTotalCost !== undefined &&
    m.aaIntelligenceIndex !== undefined,
);
const topModels = [...valueModels]
  .sort((a, b) => (b.aaBenchmarkValue ?? 0) - (a.aaBenchmarkValue ?? 0))
  .slice(0, 20);
---

<!doctype html>
<html lang="en" class="bg-neutral-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Benchmark value · Frontier</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta
      name="description"
      content="Compare model value over time as Artificial Analysis Intelligence Index divided by the cost to run the full AA benchmark."
    />
  </head>
  <body class="min-h-screen px-6 py-10 text-neutral-100">
    <main class="mx-auto flex max-w-[1400px] flex-col gap-8">
      <nav class="flex items-center gap-3 text-xs text-neutral-500">
        <a href={import.meta.env.BASE_URL} class="text-amber-300 hover:underline">← all models</a>
        <span>/</span>
        <span class="text-neutral-400">value</span>
      </nav>

      <header class="flex flex-col gap-2">
        <h1 class="text-3xl font-semibold tracking-tight">
          Intelligence per benchmark-dollar
        </h1>
        <p class="max-w-3xl text-sm text-neutral-400">
          Value chart for Artificial Analysis: intelligence index divided by
          the dollar cost to run the full AA Intelligence benchmark. Higher is
          better.
          <span class="font-mono text-neutral-300">
            {valueModels.length} / {models.length} models
          </span>
          currently have both benchmark cost and intelligence data.
        </p>
      </header>

      <BenchmarkValueTimeline client:load models={models} />

      <section class="flex flex-col gap-3">
        <div class="flex items-baseline justify-between">
          <h2 class="text-lg font-semibold text-neutral-200">Top value table</h2>
          <span class="text-xs text-neutral-500">
            Intelligence index / full AA benchmark-run cost
          </span>
        </div>
        <div class="overflow-x-auto rounded-lg border border-neutral-800 bg-neutral-900/40">
          <table class="w-full text-sm">
            <thead class="bg-neutral-900 text-left text-xs uppercase tracking-wide text-neutral-400">
              <tr>
                <th class="px-3 py-2 text-right">#</th>
                <th class="px-3 py-2">Model</th>
                <th class="px-3 py-2">Provider</th>
                <th class="px-3 py-2">Release</th>
                <th class="px-3 py-2 text-right">AA intelligence</th>
                <th class="px-3 py-2 text-right">AA bench $</th>
                <th class="px-3 py-2 text-right">Index / $</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-800">
              {topModels.map((m, i) => (
                <tr class="hover:bg-neutral-900/70">
                  <td class="px-3 py-2 text-right font-mono text-neutral-500">{i + 1}</td>
                  <td class="px-3 py-2">
                    <a
                      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/models/${m.id}/`}
                      class="font-medium text-neutral-100 hover:text-amber-300 hover:underline"
                    >
                      {m.name}
                    </a>
                  </td>
                  <td class="px-3 py-2 text-neutral-300">{m.provider}</td>
                  <td class="px-3 py-2 font-mono text-xs text-neutral-400">{m.releaseDate}</td>
                  <td class="px-3 py-2 text-right font-mono text-neutral-200">
                    {m.aaIntelligenceIndex?.toFixed(2)}
                  </td>
                  <td class="px-3 py-2 text-right font-mono text-neutral-200">
                    ${m.aaBenchmarkTotalCost?.toFixed(2)}
                  </td>
                  <td class="px-3 py-2 text-right font-mono text-amber-300">
                    {m.aaBenchmarkValue?.toFixed(3)}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>
