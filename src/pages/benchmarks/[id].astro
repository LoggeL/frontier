---
import "../../styles/global.css";
import BenchmarkDetail from "../../components/BenchmarkDetail";
import { models, benchmarks, scores } from "../../lib/data";

export function getStaticPaths() {
  return benchmarks.map((b) => ({
    params: { id: b.id },
    props: { benchmarkId: b.id },
  }));
}

const { benchmarkId } = Astro.props as { benchmarkId: string };
const benchmark = benchmarks.find((b) => b.id === benchmarkId);
if (!benchmark) throw new Error(`Unknown benchmark id: ${benchmarkId}`);
---

<!doctype html>
<html lang="en" class="bg-neutral-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{benchmark.name} · Frontier</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta
      name="description"
      content={`${benchmark.name} — leaderboard across every tracked model.`}
    />
  </head>
  <body class="min-h-screen px-6 py-10 text-neutral-100">
    <main class="mx-auto flex max-w-[1400px] flex-col gap-8">
      <nav class="flex items-center gap-3 text-xs text-neutral-500">
        <a href={import.meta.env.BASE_URL} class="text-amber-300 hover:underline">← all models</a>
        <span>/</span>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/benchmarks/`} class="text-amber-300 hover:underline">benchmarks</a>
        <span>/</span>
        <span class="text-neutral-400">{benchmark.name}</span>
      </nav>

      <BenchmarkDetail
        client:load
        benchmark={benchmark}
        benchmarks={benchmarks}
        models={models}
        scores={scores}
      />
    </main>
  </body>
</html>
